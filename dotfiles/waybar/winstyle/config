    "mpris": {
        "format": "{player_icon}   {title}",
        "format-paused": "{status_icon}   {title}",
        "tooltip-format": "{player} - {title} by {artist}",
		"truncate": 30,
		"ellipsis": true,
		"player-icons": {
			"default": "­ƒÄÁ",
